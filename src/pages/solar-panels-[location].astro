---
import Layout from '../layouts/Layout.astro';
import { Hero } from '../components/sections/Hero';
import { HowWeHelp } from '../components/sections/HowWeHelp';
import { ServicesGrid } from '../components/sections/ServicesGrid';
import { FundingSection } from '../components/sections/FundingSection';
import { CTASection } from '../components/sections/CTASection';
import { locations } from '../data/locations';

export async function getStaticPaths() {
  return locations.map((loc) => ({
    params: { location: loc.slug },
    props: { location: loc },
  }));
}

const { location } = Astro.props;
---

<Layout 
  title={`Independent Energy Consultancy in ${location.city} | Open Energy Services`} 
  description={`Looking to improve your property's energy efficiency in ${location.city}, ${location.county}? Open Energy Services provides independent advice, assesses funding eligibility, and matches you with trusted local installers.`}
>
  <div class="pt-24">
    <section class="bg-primary-navy py-20 text-white overflow-hidden relative">
      <div class="container relative z-10">
        <div class="max-w-4xl">
          <h1 class="text-[clamp(2.5rem,6vw,4.5rem)] font-bold mb-8 leading-[1.1] tracking-tighter">
            Better energy solutions for <span class="text-emerald">{location.city}</span> properties.
          </h1>
          <p class="text-xl text-slate-300 mb-10 max-w-2xl font-normal leading-relaxed">
            Join the clean energy revolution in {location.city}. We provide independent advice and connect {location.county} homeowners with accredited installation partners for insulation, heat pumps, and solar.
          </p>
          <div class="flex flex-wrap gap-6 items-center">
            <a href="/eligibility" class="px-8 py-4 bg-emerald text-white rounded-xl font-bold hover:scale-105 transition-all shadow-lg shadow-emerald/20">
              Check {location.city} Funding Eligibility
            </a>
            <div class="flex items-center gap-4 text-sm font-bold text-slate-400 uppercase tracking-widest">
              <span class="w-8 h-[1px] bg-slate-700"></span>
              Trusted Local Network
            </div>
          </div>
        </div>
      </div>
      <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-emerald/5 to-transparent -z-0"></div>
    </section>

    <HowWeHelp client:visible />
    
    <section class="py-24 bg-bg-grey border-y border-slate-100">
      <div class="container">
        <div class="max-w-3xl">
          <h2 class="text-4xl font-bold text-primary-navy mb-6 tracking-tight">Why Choose OES in {location.city}?</h2>
          <p class="text-lg text-slate-600 mb-8 font-medium">
            As a leading independent energy consultancy serving {location.city} and the wider {location.county} area, we understand local funding opportunities and property types. We don't install systems ourselves; instead, we match you with the best accredited local professionals.
          </p>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <div class="w-6 h-6 bg-emerald-light rounded-full flex items-center justify-center text-emerald mt-1 font-bold">✓</div>
              <p class="text-slate-700 font-medium"><strong>Local Knowledge:</strong> Our network includes vetted installers based near {location.city}, ensuring fast response times and regional expertise.</p>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-6 h-6 bg-emerald-light rounded-full flex items-center justify-center text-emerald mt-1 font-bold">✓</div>
              <p class="text-slate-700 font-medium"><strong>Independent Advice:</strong> We provide unbiased recommendations tailored to your {location.city} property, not sales pitches.</p>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-6 h-6 bg-emerald-light rounded-full flex items-center justify-center text-emerald mt-1 font-bold">✓</div>
              <p class="text-slate-700 font-medium"><strong>Maximum Funding:</strong> We assess your eligibility for {location.city}-specific grants alongside national schemes like ECO4 and GBIS.</p>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <ServicesGrid client:visible />
    <FundingSection client:visible />
    <CTASection client:visible />
  </div>
</Layout>
