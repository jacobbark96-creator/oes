---
import Layout from '../layouts/Layout.astro';
import { ServicesGrid } from '../components/sections/ServicesGrid';
import { CTASection } from '../components/sections/CTASection';
---

<Layout 
  title="Independent Energy Services & Advice | Open Energy Services" 
  description="Discover our comprehensive independent energy services. We match you with accredited specialists for solar panels, heat pumps, insulation, and battery storage across the UK."
>
  <div class="pt-32 pb-12 bg-white text-center">
    <div class="container max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-primary-navy tracking-tighter mb-6">
        Our Energy Services
      </h1>
      <p class="text-lg md:text-xl text-slate-600 font-medium leading-relaxed">
        From initial assessment to final installation, we coordinate your entire energy efficiency upgrade. Explore the technologies our accredited partners install.
      </p>
    </div>
  </div>
  <ServicesGrid client:load />
  <CTASection client:visible />
</Layout>