---
import Layout from '../layouts/Layout.astro';
import { FundingSection } from '../components/sections/FundingSection';
import { CTASection } from '../components/sections/CTASection';
---

<Layout 
  title="Government Funding for Energy Upgrades | Open Energy Services" 
  description="Find out if you qualify for government grants like ECO4 or GBIS. We help you navigate funding options for your home energy improvements."
>
  <div class="pt-32 pb-12 bg-white text-center">
    <div class="container max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-primary-navy tracking-tighter mb-6">
        Government Funding & Grants
      </h1>
      <p class="text-lg md:text-xl text-slate-600 font-medium leading-relaxed">
        Navigate the complexities of UK energy grants. We help you check your eligibility for schemes like ECO4 and GBIS, ensuring you get the financial support you deserve.
      </p>
    </div>
  </div>
  <FundingSection client:load />
  <CTASection client:visible />
</Layout>