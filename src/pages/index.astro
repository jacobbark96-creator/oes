---
import Layout from '../layouts/Layout.astro';
import { Hero } from '../components/sections/Hero';
import { TrustBar } from '../components/sections/TrustBar';
import { HowWeHelp } from '../components/sections/HowWeHelp';
import { HowItWorks } from '../components/sections/HowItWorks';
import { ServicesGrid } from '../components/sections/ServicesGrid';
import { FundingSection } from '../components/sections/FundingSection';
import { WhyOES } from '../components/sections/WhyOES';
import { UKCoverage } from '../components/sections/UKCoverage';
import { Reviews } from '../components/sections/Reviews';
import { Accreditations } from '../components/sections/Accreditations';
import { FAQ } from '../components/sections/FAQ';
import { CTASection } from '../components/sections/CTASection';
---

<Layout 
  title="Independent Energy Consultancy | Open Energy Services" 
  description="Open Energy Services helps homeowners, landlords, and businesses access government funding and connect with trusted, accredited installation partners across the UK."
>
  <Hero client:load />
  <TrustBar client:visible />
  <HowWeHelp client:visible />
  <HowItWorks client:visible />
  <ServicesGrid client:visible />
  <FundingSection client:visible />
  <WhyOES client:visible />
  <UKCoverage client:visible />
  <Reviews client:visible />
  <Accreditations client:visible />
  <FAQ client:visible />
  <CTASection client:visible />
</Layout>
