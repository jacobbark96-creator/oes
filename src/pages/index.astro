---
import Layout from '../layouts/Layout.astro';
import { Hero } from '../components/sections/Hero';
import { Services } from '../components/sections/Services';
import { Finance } from '../components/sections/Finance';
import { AboutSection } from '../components/sections/About';
import { CTASection } from '../components/sections/CTA';
import { ScrollProgress } from '../components/layout/ScrollProgress';
---

<Layout 
  title="Expert Solar Panel Installation UK | Open Energy Solutions" 
  description="Open Energy Solutions (OES) provides premium solar panel installations, battery storage, and EV charging across the UK. Slash your energy bills with our expert solar solutions. Get a free quote!"
>
  <ScrollProgress client:load />
  <Hero client:load />
  <AboutSection client:visible />
  <Services client:visible />
  <Finance client:visible />
  <CTASection client:visible />
</Layout>
