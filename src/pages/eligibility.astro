---
import Layout from '../layouts/Layout.astro';
import { CTASection } from '../components/sections/CTASection';
---

<Layout 
  title="Check Your Eligibility | Open Energy Services" 
  description="Check if you qualify for government funding like ECO4 or GBIS for your property's energy efficiency upgrades."
>
  <div class="pt-32 pb-24 bg-bg-grey">
    <div class="container max-w-3xl text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-primary-navy mb-6 tracking-tight leading-tight">
        Check your eligibility.
      </h1>
      <p class="text-lg text-slate-600 mb-12 font-medium">
        Contact our team of funding specialists to find out if your property qualifies for government grants like ECO4, GBIS, or local authority schemes.
      </p>

      <div class="bg-white p-8 md:p-12 rounded-[2rem] shadow-glass border border-slate-100 text-left">
        <h2 class="text-2xl font-bold text-primary-navy mb-6">Start Your Assessment</h2>
        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="p-3 bg-emerald-light rounded-xl text-emerald">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div>
              <p class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-1">Call our specialists</p>
              <a href="tel:+441615245535" class="text-lg font-medium text-primary-navy hover:text-emerald transition-colors">+44 161 524 5535</a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="p-3 bg-emerald-light rounded-xl text-emerald">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </div>
            <div>
              <p class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-1">Email us your details</p>
              <a href="mailto:welcome@openenergyservices.co.uk?subject=Eligibility Check Request" class="text-lg font-medium text-primary-navy hover:text-emerald transition-colors">welcome@openenergyservices.co.uk</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <CTASection client:visible />
</Layout>