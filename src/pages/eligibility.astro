---
import Layout from '../layouts/Layout.astro';
import { Wizard } from '../components/wizard/Wizard';
import { CTASection } from '../components/sections/CTASection';
---

<Layout 
  title="Check Your Eligibility | Open Energy Services" 
  description="Check if you qualify for government funding like ECO4 or GBIS for your property's energy efficiency upgrades."
>
  <div class="pt-32 pb-24 bg-bg-grey">
    <div class="container max-w-4xl text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-primary-navy mb-6 tracking-tight leading-tight">
        Check your eligibility.
      </h1>
      <p class="text-lg text-slate-600 mb-12 font-medium max-w-2xl mx-auto">
        Complete our quick assessment to find out if your property qualifies for government grants like ECO4, GBIS, or local authority schemes.
      </p>

      <Wizard client:load />
    </div>
  </div>
  <CTASection client:visible />
</Layout>